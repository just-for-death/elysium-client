# Elysium – environment template
# Copy this file to .env and fill in real values.
# In Docker, pass these via docker-compose environment: instead.
# Leave REACT_APP_API_URL empty for self-hosted (uses same origin for /api/countryCode)
REACT_APP_API_URL=


# ── API Authentication (optional) ─────────────────────────────────────────────
# Set to any long random string to require Authorization: Bearer <secret> on all
# /api/v1/library/* and /api/v1/scrobble calls.
# Leave empty for open (LAN-only) deployments.
API_SECRET=

# ── Web Push (optional – push notifications) ──────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:you@example.com

# Protect the /push/broadcast endpoint with a secret token
# Set to any long random string, then include as Authorization: Bearer <secret>
BROADCAST_SECRET=

# ── Gotify proxy (optional) ───────────────────────────────────────────────────
# Set to your Gotify server URL (e.g. https://gotify.example.com) to enable
# the server-side Gotify proxy. Left empty = proxy disabled.
GOTIFY_SERVER_URL=

# ── Set to true only when serving behind an HTTPS reverse proxy ───────────────
ENABLE_HSTS=false
